# ============================================
# Iteyes Open WebUI RAG - 폐쇄망 DGX 배포 모드
# dgx/install.sh가 자동으로 airgap.env를 생성한다.
# ============================================

# === Core ===
# dgx/install.sh가 자동 생성하거나, openssl rand -hex 32 로 직접 생성
WEBUI_SECRET_KEY=<dgx/install.sh가 자동 생성>
ENV=prod

# === LLM Endpoint (DGX 외부 LLM 서비스) ===
# 이 프로젝트는 LLM 모델을 직접 서빙하지 않습니다.
# DGX에서 실행 중인 vLLM/Ollama 등 외부 LLM 서비스에 연결합니다.
#
# --- OpenAI 호환 API (기본값: DGX 호스트에서 vLLM Docker 실행 중인 경우) ---
# host.docker.internal → 컨테이너에서 DGX 호스트 머신으로 접근
# vLLM 실행: docker run -d --gpus all --ipc=host -v ~/.cache/huggingface:/root/.cache/huggingface
#            -e HF_HUB_OFFLINE=1 -p 8000:8000 nvcr.io/nvidia/vllm:25.12.post1-py3
#            vllm serve <model_id> --host 0.0.0.0 --port 8000
ENABLE_OPENAI_API=true
OPENAI_API_BASE_URL=http://host.docker.internal:8000/v1
OPENAI_API_KEY=dummy-key-for-local-vllm
#
# --- Ollama API (Ollama 사용 시 아래 주석 해제, 위 OpenAI 설정 비활성화) ---
ENABLE_OLLAMA_API=false
OLLAMA_BASE_URL=http://host.docker.internal:11434

# === Database (PostgreSQL) ===
# dgx/install.sh가 POSTGRES_PASSWORD를 자동 생성하고 DATABASE_URL도 함께 갱신
POSTGRES_PASSWORD=<dgx/install.sh가 자동 생성>
DATABASE_URL=postgresql://openwebui:<POSTGRES_PASSWORD>@postgres:5432/openwebui

# === Vector DB (Qdrant) ===
VECTOR_DB=qdrant
QDRANT_URI=http://qdrant:6333

# === HuggingFace Offline Mode ===
# 폐쇄망 환경: 반드시 1로 유지 (모델은 dgx/install.sh에서 사전 캐시됨)
HF_HUB_OFFLINE=1

# === RAG Embedding ===
RAG_EMBEDDING_ENGINE=
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_EMBEDDING_MODEL_AUTO_UPDATE=false
RAG_EMBEDDING_MODEL_TRUST_REMOTE_CODE=true

# === RAG Reranking ===
# 비활성화: 소규모 코퍼스 + bge-m3 임베딩으로 충분한 품질
# 활성화 시: RAG_RERANKING_MODEL=BAAI/bge-reranker-v2-m3 (쿼리당 1~3초 추가)
RAG_RERANKING_MODEL=

# === RAG Search ===
RAG_TOP_K=8
RAG_TOP_K_RERANKER=8
ENABLE_RAG_HYBRID_SEARCH=true
RAG_RELEVANCE_THRESHOLD=0.1

# === RAG Prompt (영어 지시문 - instruction following 최적화 + 엑셀 표 인식) ===
RAG_TEMPLATE=You are an expert analyst answering questions based on internal company documents. Always respond in Korean.\n\n[Instructions]\n1. Use ALL relevant information from every document included in the context below.\n2. If related information is found across multiple documents, organize it by document.\n3. Always cite the source of each piece of information using the format [document name].\n4. Use structured formats such as tables or lists when appropriate.\n5. Only say "제공된 문서에서 해당 정보를 찾을 수 없습니다" if the context contains NO relevant information.\n6. Never guess or fabricate information not present in the context.\n\n[Excel Data Guidelines]\n- Data separated by tabs or spaces represents rows and columns of an Excel spreadsheet.\n- Headers may be cut off at chunk boundaries; infer structure from data patterns (numeric columns, date formats, code values, etc.).\n- Always quote numeric, date, and code values exactly as they appear in the source.\n- If related data is spread across multiple chunks, consolidate it into a single table.\n\n[Context]\n{{CONTEXT}}\n\n[Question]\n{{QUERY}}\n\n[Answer]

# === LLM Default Parameters (RAG 최적화) ===
DEFAULT_TEMPERATURE=0.3
DEFAULT_TOP_P=0.9
DEFAULT_TOP_K=40
DEFAULT_MIN_P=0.05
DEFAULT_REPEAT_PENALTY=1.1
DEFAULT_FREQUENCY_PENALTY=0.1
DEFAULT_MAX_TOKENS=2048
DEFAULT_NUM_CTX=8192

# === Content Extraction (Tika) ===
CONTENT_EXTRACTION_ENGINE=tika
TIKA_SERVER_URL=http://tika:9998

# === Chat Title Generation (이모티콘 제거) ===
TITLE_GENERATION_PROMPT_TEMPLATE=다음 대화의 핵심 내용을 한국어로 5단어 이내의 짧은 제목으로 작성하세요. 이모티콘 없이 텍스트만 사용하세요.\n\n대화: {{MESSAGES:END:2}}\n\n제목:

# === Logging ===
GLOBAL_LOG_LEVEL=INFO
